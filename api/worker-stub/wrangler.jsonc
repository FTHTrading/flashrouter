    { "pattern": "eth.flashrouter.io/*", "zone_name": "flashrouter.io" },
    { "pattern": "ipfs.flashrouter.io/*", "zone_name": "flashrouter.io" },
    { "pattern": "sol.flashrouter.io/*", "zone_name": "flashrouter.io" },
    { "pattern": "helius.flashrouter.io/*", "zone_name": "flashrouter.io" }
  ]
}
