{
  "name": "@flashrouter/sdk",
  "version": "0.1.0",
  "description": "FlashRouter SDK — one API for every flash loan provider, every EVM chain.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "flash-loan",
    "flash-mint",
    "aave",
    "balancer",
    "uniswap",
    "makerdao",
    "defi",
    "arbitrage",
    "ethereum",
    "base",
    "arbitrum",
    "optimism",
    "bnb",
    "polygon"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flashrouter/flashrouter"
  },
  "homepage": "https://flashrouter.io",
  "bugs": {
    "url": "https://github.com/flashrouter/flashrouter/issues"
  }
}
